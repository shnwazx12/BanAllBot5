# ════════════════════════════════════════════════
#   @HiddenEntryBot  ·  Environment Configuration
#   1. Copy this file:  cp .env.example .env
#   2. Fill in all values below
# ════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────
# Get from @BotFather → /newbot
BOT_TOKEN=123456789:ABCDefgh_your_token_here

# Your Telegram numeric user ID  (get from @userinfobot)
OWNER_ID=987654321

# ── MongoDB Atlas ─────────────────────────────────
# mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/hiddenentrybot?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/hiddenentrybot

# ── Render.com ────────────────────────────────────
# Your Render service public URL — NO trailing slash
# Leave BLANK for local polling mode
# Example: https://hidden-entry-bot.onrender.com
RENDER_URL=

# Port (Render sets this automatically; 3000 is fine locally)
PORT=3000
